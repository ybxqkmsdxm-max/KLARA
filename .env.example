# Copy this file to .env.local and fill real values

DATABASE_URL="file:./db/custom.db"
NEXTAUTH_SECRET="replace-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

# Shared auth rate limit (required in production multi-instance)
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# Optional auth rate limit tuning
AUTH_RATE_LIMIT_WINDOW_MS="60000"
AUTH_RATE_LIMIT_MAX="12"
DISABLE_AUTH_RATE_LIMIT="false"

# Demo account (optional)
DEMO_USER_EMAIL="aminata@boutique-excellence.tg"
DEMO_USER_PASSWORD="demo1234"
DEMO_USER_NAME="Aminata Mensah"
NEXT_PUBLIC_DEMO_EMAIL="aminata@boutique-excellence.tg"
NEXT_PUBLIC_DEMO_PASSWORD="demo1234"
